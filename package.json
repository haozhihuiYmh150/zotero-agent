{
  "name": "zotero-agent",
  "type": "module",
  "version": "0.2.0",
  "description": "Zotero AI Agent - Search, download, and analyze papers with LLM",
  "config": {
    "addonName": "Zotero Agent",
    "addonID": "zotero-agent@haozhihuiYmh150",
    "addonRef": "zoteroagent",
    "addonInstance": "ZoteroAgent",
    "prefsPrefix": "extensions.zotero.zoteroagent"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/haozhihuiYmh150/zotero-agent.git"
  },
  "author": "haozhihuiYmh150",
  "bugs": {
    "url": "https://github.com/haozhihuiYmh150/zotero-agent/issues"
  },
  "homepage": "https://github.com/haozhihuiYmh150/zotero-agent#readme",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "start": "zotero-plugin serve",
    "build": "zotero-plugin build && tsc --noEmit",
    "lint:check": "prettier --check . && eslint .",
    "lint:fix": "prettier --write . && eslint . --fix",
    "release": "zotero-plugin release",
    "test": "zotero-plugin test",
    "update-deps": "npm update --save"
  },
  "dependencies": {
    "compute-cosine-similarity": "^1.1.0",
    "crypto-js": "^4.2.0",
    "katex": "^0.16.45",
    "markdown-it": "^14.1.0",
    "marked": "^18.0.2",
    "marked-katex-extension": "^5.1.8",
    "zotero-plugin-toolkit": "^5.1.2"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/crypto-js": "^4.2.2",
    "@types/markdown-it": "^14.1.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.10.0",
    "@zotero-plugin/eslint-config": "^0.6.9",
    "chai": "^6.2.2",
    "eslint": "^9.39.2",
    "mocha": "^11.7.5",
    "prettier": "^3.8.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "zotero-plugin-scaffold": "^0.8.6",
    "zotero-types": "^4.1.2"
  },
  "prettier": {
    "printWidth": 80,
    "tabWidth": 2,
    "endOfLine": "lf",
    "overrides": [
      {
        "files": [
          "*.xhtml"
        ],
        "options": {
          "htmlWhitespaceSensitivity": "css"
        }
      }
    ]
  }
}
